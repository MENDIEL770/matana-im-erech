generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  role          Role      @default(CUSTOMER)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer  Customer?
  agent     Agent?
  accounts  Account[]
  sessions  Session[]
}

enum Role {
  ADMIN
  CUSTOMER
  AGENT
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
}

// ==================== CUSTOMERS ====================

model Customer {
  id              String         @id @default(cuid())
  userId          String?        @unique
  chabadHouseName String
  shaliachName    String
  phone           String
  email           String         @unique
  address         String?
  city            String?
  country         String?
  website         String?
  businessNumber  String?
  tier            CustomerTier   @default(REGULAR)
  totalSpent      Decimal        @default(0) @db.Decimal(12, 2)
  notes           String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  marketingConsent    Boolean        @default(false)
  directDebitInterest Boolean        @default(false)

  // Dokopoint sync
  dokopointCustomerId Int?
  dokopointSyncedAt   DateTime?

  user            User?          @relation(fields: [userId], references: [id])
  orders          Order[]
  quotes          Quote[]
  leads           Lead[]
  agentCustomers  AgentCustomer[]
  subscriptions   CustomerSubscription[]
}

enum CustomerTier {
  GOLD
  SILVER
  REGULAR
}

// ==================== CATEGORIES ====================

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
}

// ==================== PRODUCTS ====================

model Product {
  id               String          @id @default(cuid())
  name             String
  sku              String          @unique
  categoryId       String?
  shortDescription String?
  description      String?
  productType      ProductType     @default(MANUFACTURED)

  costPrice        Decimal         @default(0) @db.Decimal(10, 2)
  regularPrice     Decimal         @default(0) @db.Decimal(10, 2)
  price20          Decimal?        @db.Decimal(10, 2)
  price50          Decimal?        @db.Decimal(10, 2)
  price100         Decimal?        @db.Decimal(10, 2)
  price250         Decimal?        @db.Decimal(10, 2)
  price500         Decimal?        @db.Decimal(10, 2)
  minPrice         Decimal?        @db.Decimal(10, 2)
  minQuantity      Int             @default(1)

  hasEmbroidery    Boolean         @default(false)
  embroideryPrice  Decimal?        @db.Decimal(10, 2)
  hasEngraving     Boolean         @default(false)
  engravingPrice   Decimal?        @db.Decimal(10, 2)
  hasLogoprint     Boolean         @default(false)
  logoprintPrice   Decimal?        @db.Decimal(10, 2)
  hasEmbossing     Boolean         @default(false)
  embossingPrice   Decimal?        @db.Decimal(10, 2)
  hasPersonal      Boolean         @default(false)

  isCustomizable   Boolean         @default(false)
  customFonts      Json?

  stock            Int             @default(0)
  minStock         Int             @default(5)
  warehouseLocation String?

  supplierName     String?
  supplierPhone    String?
  supplierEmail    String?
  leadTimeDays     Int?
  originCountry    String?

  tag              ProductTag?
  holidays         String[]
  isFeatured       Boolean         @default(false)
  isNew            Boolean         @default(false)
  isActive         Boolean         @default(true)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Dokopoint sync
  dokopointProductId Int?
  dokopointSyncedAt  DateTime?

  category         Category?       @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  costs            ProductCost[]
  fields           ProductField[]
  quoteItems       QuoteItem[]
  orderItems       OrderItem[]
  inventoryLogs    InventoryLog[]
}

enum ProductType {
  MANUFACTURED
  PURCHASED
  IMPORTED
  SPECIAL_ORDER
}

enum ProductTag {
  NEW
  RECOMMENDED
  POPULAR
  PREMIUM
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  isHover   Boolean  @default(false)
  isVideo   Boolean  @default(false)
  order     Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductCost {
  id          String   @id @default(cuid())
  productId   String
  label       String
  amount      Decimal  @db.Decimal(10, 2)
  isPercent   Boolean  @default(false)
  order       Int      @default(0)

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductField {
  id           String      @id @default(cuid())
  productId    String
  fieldKey     String
  label        String
  fieldType    FieldType   @default(TEXT)
  isRequired   Boolean     @default(false)
  isForExcel   Boolean     @default(true)
  order        Int         @default(0)

  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum FieldType {
  TEXT
  PHONE
  EMAIL
  ADDRESS
  TEXTAREA
  FILE
}

// ==================== CRM ====================

model Lead {
  id            String         @id @default(cuid())
  customerId    String?
  chabadHouse   String
  contactName   String
  phone         String
  email         String?
  source        String?
  status        LeadStatus     @default(NEW)
  notes         String?
  assignedTo    String?
  expectedValue Decimal?       @db.Decimal(10, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  customer      Customer?      @relation(fields: [customerId], references: [id])
  activities    LeadActivity[]
  tasks         Task[]
}

enum LeadStatus {
  NEW
  CONTACTED
  WAITING
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
  CANCELLED
}

model LeadActivity {
  id        String       @id @default(cuid())
  leadId    String
  type      ActivityType
  content   String
  createdBy String?
  createdAt DateTime     @default(now())

  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  WHATSAPP
  STATUS_CHANGE
}

model Task {
  id          String    @id @default(cuid())
  leadId      String?
  orderId     String?
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  assignedTo  String?
  createdAt   DateTime  @default(now())

  lead        Lead?     @relation(fields: [leadId], references: [id])
  order       Order?    @relation(fields: [orderId], references: [id])
}

// ==================== QUOTES ====================

model Quote {
  id           String       @id @default(cuid())
  quoteNumber  String       @unique
  customerId   String
  status       QuoteStatus  @default(DRAFT)
  validUntil   DateTime?
  notes        String?
  internalNote String?
  discount     Decimal      @default(0) @db.Decimal(10, 2)
  discountType DiscountType @default(FIXED)
  subtotal     Decimal      @default(0) @db.Decimal(10, 2)
  total        Decimal      @default(0) @db.Decimal(10, 2)
  totalCost    Decimal      @default(0) @db.Decimal(10, 2)
  profit       Decimal      @default(0) @db.Decimal(10, 2)
  sentAt       DateTime?
  approvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  customer     Customer     @relation(fields: [customerId], references: [id])
  items        QuoteItem[]
  order        Order?
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum DiscountType {
  FIXED
  PERCENT
}

model QuoteItem {
  id             String   @id @default(cuid())
  quoteId        String
  productId      String?
  name           String
  description    String?
  quantity       Int
  unitPrice      Decimal  @db.Decimal(10, 2)
  unitCost       Decimal  @default(0) @db.Decimal(10, 2)
  customizations Json?
  total          Decimal  @db.Decimal(10, 2)

  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id])
}

// ==================== ORDERS ====================

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerId      String
  quoteId         String?       @unique
  status          OrderStatus   @default(NEW)
  paymentStatus   PaymentStatus @default(PENDING)
  shippingType    ShippingType  @default(CONSOLIDATED)
  shippingAddress Json?
  notes           String?
  internalNote    String?
  couponCode      String?
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  shippingCost    Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @default(0) @db.Decimal(10, 2)
  totalCost       Decimal       @default(0) @db.Decimal(10, 2)
  profit          Decimal       @default(0) @db.Decimal(10, 2)
  agentId         String?
  agentCommission Decimal       @default(0) @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Dokopoint sync
  dokopointOrderId Int?
  dokopointDocId   Int?
  dokopointSyncedAt DateTime?

  customer        Customer      @relation(fields: [customerId], references: [id])
  quote           Quote?        @relation(fields: [quoteId], references: [id])
  agent           Agent?        @relation(fields: [agentId], references: [id])
  items           OrderItem[]
  uploads         OrderUpload[]
  payments        Payment[]
  shipments       Shipment[]
  tasks           Task[]
  invoice         Invoice?
}

enum OrderStatus {
  NEW
  WAITING_PAYMENT
  PAID
  IN_PRODUCTION
  READY
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum ShippingType {
  CONSOLIDATED
  DIRECT_TO_DONORS
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String?
  name           String
  quantity       Int
  unitPrice      Decimal  @db.Decimal(10, 2)
  unitCost       Decimal  @default(0) @db.Decimal(10, 2)
  customizations Json?
  excelData      Json?
  total          Decimal  @db.Decimal(10, 2)

  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id])
}

model OrderUpload {
  id         String   @id @default(cuid())
  orderId    String
  filename   String
  url        String
  uploadedAt DateTime @default(now())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ==================== PAYMENTS ====================

model Payment {
  id           String        @id @default(cuid())
  orderId      String
  amount       Decimal       @db.Decimal(10, 2)
  method       PaymentMethod
  status       String        @default("pending")
  reference    String?
  providerData Json?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())

  order        Order         @relation(fields: [orderId], references: [id])
}

enum PaymentMethod {
  CREDIT_CARD
  APPLE_PAY
  GOOGLE_PAY
  BIT
  BANK_TRANSFER
  INVOICE
}

// ==================== SHIPMENTS ====================

model Shipment {
  id             String         @id @default(cuid())
  orderId        String
  provider       String?
  trackingNumber String?
  status         ShipmentStatus @default(PENDING)
  estimatedDate  DateTime?
  deliveredAt    DateTime?
  providerData   Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order          Order          @relation(fields: [orderId], references: [id])
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

// ==================== AGENTS ====================

model Agent {
  id             String          @id @default(cuid())
  userId         String?         @unique
  name           String
  phone          String
  email          String          @unique
  commissionRate Decimal         @default(0) @db.Decimal(5, 2)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())

  user           User?           @relation(fields: [userId], references: [id])
  orders         Order[]
  agentCustomers AgentCustomer[]
}

model AgentCustomer {
  agentId    String
  customerId String
  assignedAt DateTime @default(now())

  agent      Agent    @relation(fields: [agentId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  @@id([agentId, customerId])
}

// ==================== COUPONS ====================

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  type           DiscountType @default(PERCENT)
  value          Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal?     @db.Decimal(10, 2)
  expiresAt      DateTime?
  maxUses        Int?
  usedCount      Int          @default(0)
  maxUsesPerUser Int?
  agentId        String?
  holiday        String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
}

// ==================== INVENTORY ====================

model InventoryLog {
  id        String        @id @default(cuid())
  productId String
  type      InventoryType
  quantity  Int
  reason    String?
  reference String?
  createdAt DateTime      @default(now())

  product   Product       @relation(fields: [productId], references: [id])
}

enum InventoryType {
  IN
  OUT
  ADJUSTMENT
}

// ==================== INVOICES ====================

model Invoice {
  id            String      @id @default(cuid())
  orderId       String      @unique
  invoiceNumber String      @unique
  type          InvoiceType @default(TAX)
  providerRef   String?
  url           String?
  amount        Decimal     @db.Decimal(10, 2)
  issuedAt      DateTime    @default(now())

  order         Order       @relation(fields: [orderId], references: [id])
}

enum InvoiceType {
  TAX
  RECEIPT
  CREDIT
}

// ==================== NOTIFICATIONS & SMS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  message   String
  status    String   @default("pending")
  provider  String?
  reference String?
  sentAt    DateTime @default(now())
}

// ==================== MARKETING ====================

model SubscriptionList {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  description String?
  createdAt   DateTime               @default(now())

  subscribers CustomerSubscription[]
}

model CustomerSubscription {
  customerId String
  listId     String
  joinedAt   DateTime @default(now())

  customer   Customer         @relation(fields: [customerId], references: [id])
  list       SubscriptionList @relation(fields: [listId], references: [id])

  @@id([customerId, listId])
}

// ==================== REPORTS ====================

model MonthlyReport {
  id                String   @id @default(cuid())
  year              Int
  month             Int
  totalRevenue      Decimal  @db.Decimal(12, 2)
  totalCost         Decimal  @db.Decimal(12, 2)
  grossProfit       Decimal  @db.Decimal(12, 2)
  operatingExpenses Decimal  @db.Decimal(12, 2)
  netProfit         Decimal  @db.Decimal(12, 2)
  partnerPercent    Decimal  @db.Decimal(5, 2)
  partnerPayment    Decimal  @db.Decimal(12, 2)
  data              Json?
  createdAt         DateTime @default(now())

  @@unique([year, month])
}

// ==================== DOKOPOINT ====================

model DokopointSyncLog {
  id           String   @id @default(cuid())
  entityType   String   // 'customer' | 'product' | 'order' | 'document' | 'cron'
  entityId     String?
  dokopointId  Int?
  action       String   // 'create' | 'update' | 'sync'
  status       String   // 'success' | 'error'
  errorMessage String?
  createdAt    DateTime @default(now())
}
